# Copy this file to .env and adjust for your environment
# .env is gitignored — safe to put personal paths here

# Media input/output directories (for docker-compose volume mounts)
MEDIA_ROOT=/path/to/your/media
MODELS_ROOT=/path/to/your/models

# API keys (optional, for cloud services)
# DEEPL_API_KEY=your-deepl-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# GPU Worker (for CUDA inference on host machine)
# GPU_WORKER_URL=http://host.docker.internal:9001
